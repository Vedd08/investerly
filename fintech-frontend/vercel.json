{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "login.investerly.in"
        }
      ],
      "destination": "https://investerly.onrender.com/legacy-proxy/$1"
    },
    {
      "source": "/login.php",
      "destination": "https://investerly.onrender.com/legacy-login"
    },
